# Toast

# # Production
# CLIENT_ID=""
# CLIENT_SECRET=""

# TOAST_URL="https://app.toast.sh"

# localhost
CLIENT_ID="toast-app-client"
CLIENT_SECRET="toast-app-secret"

TOAST_URL="http://localhost:3030"

NODE_ENV="development"

# 토큰 만료 시간(초) 설정
# - 2592000 은 30일 (기본 설정)
# - 0 또는 음수 값(-1)을 설정하면 무제한(사실상 영구) 토큰으로 설정됩니다
TOKEN_EXPIRES_IN="2592000"

# 무제한 토큰으로 설정하려면 아래 줄의 주석을 제거하세요
# TOKEN_EXPIRES_IN="0"
